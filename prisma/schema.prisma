generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Job {
  id              String   @id @default(cuid())
  state           String   @default("NEW")
  inputRequest    String
  customerId      String?
  priority        Int      @default(5)
  modelId         String?
  partFamily      String?
  builderName     String?
  generationPath  String?
  scadSource      String?
  parameterSchema String?
  parameterValues String?
  researchResult  String?
  intentResult    String?
  designResult    String?
  stlPath         String?
  pngPath         String?
  renderLog       String?
  reportPath      String?
  validationResults String?
  executionLogs   String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  notes           String?
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  parent          Job?     @relation("JobHierarchy", fields: [parentId], references: [id])
  children        Job[]    @relation("JobHierarchy")
  versions        JobVersion[]

  @@index([priority, createdAt])
  @@index([state, priority, createdAt])
  @@index([parentId])
}

model JobVersion {
  id          String   @id @default(cuid())
  jobId       String
  field       String   // which field changed: "parameters", "scadSource", "notes"
  oldValue    String?  // JSON string of previous value
  newValue    String?  // JSON string of new value
  changedBy   String   @default("user")  // who made the change
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
