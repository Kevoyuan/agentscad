// Clip Basic Template v1
// Generated by CAD Agent System
// Material: {{ material }}
// Tolerance: {{ tolerance }}mm

// Parameters
length = {{ length }};
width = {{ width }};
height = {{ height }};
wall_thickness = {{ wall_thickness }};

clip_inner_diameter = {{ clip_inner_diameter }};
clip_outer_diameter = {{ clip_outer_diameter }};
clip_width = {{ clip_width }};

$fn = 64;

// Outer ring
difference() {
    cylinder(h=clip_width, d=clip_outer_diameter, center=false);
    translate([0, 0, -0.1])
        cylinder(h=clip_width + 0.2, d=clip_inner_diameter, center=false);
}

// Clip arms
arm_width = (clip_outer_diameter - clip_inner_diameter) / 2;
arm_length = length - clip_outer_diameter/2;

translate([clip_outer_diameter/2 - arm_width/2, clip_width/2 - arm_width/2, 0])
    cube([arm_width, arm_length, wall_thickness], center=false);

translate([clip_outer_diameter/2 - arm_width/2, clip_width/2 - arm_width/2, clip_width - wall_thickness])
    cube([arm_width, arm_length, wall_thickness], center=false);

// Snap tabs
tab_size = wall_thickness;
translate([clip_outer_diameter/2 - tab_size/2, length - tab_size*2, clip_width/2 - tab_size/2])
    cube([tab_size, tab_size, tab_size], center=false);
