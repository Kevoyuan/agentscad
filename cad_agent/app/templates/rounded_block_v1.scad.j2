// Material: {{ material }}
// Tolerance: {{ tolerance }}mm

length = {{ length }};
width = {{ width }};
height = {{ height }};
fillet_radius = {{ fillet_radius }};

$fn = 64;

safe_fillet = min(
    fillet_radius,
    length / 2 - 0.01,
    width / 2 - 0.01,
    height / 2 - 0.01
);

module rounded_block(l, w, h, r) {
    if (r <= 0) {
        cube([l, w, h], center = false);
    } else {
        translate([r, r, r])
            minkowski() {
                cube([l - 2 * r, w - 2 * r, h - 2 * r], center = false);
                sphere(r = r);
            }
    }
}

rounded_block(length, width, height, safe_fillet);
