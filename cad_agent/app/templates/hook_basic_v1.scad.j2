// Hook Basic Template v1
// Generated by CAD Agent System
// Material: {{ material }}
// Tolerance: {{ tolerance }}mm

// Parameters
length = {{ length }};
width = {{ width }};
height = {{ height }};
wall_thickness = {{ wall_thickness }};

hook_diameter = {{ hook_diameter }};
hook_length = {{ hook_length }};
hook_angle = {{ hook_angle }};

$fn = 64;

// Base plate
difference() {
    cube([length, width, wall_thickness], center=false);
    translate([wall_thickness, wall_thickness, -0.1])
        cube([length - 2*wall_thickness, width - 2*wall_thickness, wall_thickness + 0.2], center=false);
}

// Hook shaft
translate([length/2 - wall_thickness/2, width/2, wall_thickness])
    cylinder(h=hook_length, d=wall_thickness * 2, center=false);

// Hook curve
translate([length/2 - wall_thickness/2, width/2, wall_thickness + hook_length])
    rotate([0, hook_angle, 0])
        translate([0, 0, -hook_diameter/2])
            rotate([90, 0, 0])
                difference() {
                    cylinder(h=hook_diameter/2 + wall_thickness, d=hook_diameter + wall_thickness*2, center=false);
                    translate([0, 0, -0.1])
                        cylinder(h=hook_diameter/2 + wall_thickness + 0.2, d=hook_diameter, center=false);
                }
