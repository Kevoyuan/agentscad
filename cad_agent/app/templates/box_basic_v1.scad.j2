// Box Basic Template v1
// Generated by CAD Agent System
// Material: {{ material }}
// Tolerance: {{ tolerance }}mm

// Parameters
length = {{ length }};
width = {{ width }};
height = {{ height }};
wall_thickness = {{ wall_thickness }};

$fn = 64;

// Box body - hollow
difference() {
    cube([length, width, height], center=false);
    
    translate([wall_thickness, wall_thickness, wall_thickness])
        cube([length - 2*wall_thickness, width - 2*wall_thickness, height], center=false);
}

// Finger notch for easy opening
translate([length - 5, width/2, height/2])
    rotate([90, 0, 0])
        cylinder(h=8, d=4, center=false);

// Lid groove
translate([0, 0, height - wall_thickness/2])
    cube([length, width, wall_thickness/2], center=false);
