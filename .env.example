# Database URL for Prisma (SQLite by default)
DATABASE_URL="file:../db/dev.db"

# Xiaomi MiMo OpenAI-compatible API
MIMO_BASE_URL="https://token-plan-cn.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"
# MIMO_API_KEY=""

# DeepSeek OpenAI-compatible API
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
# DEEPSEEK_API_KEY=""

# OpenRouter OpenAI-compatible API
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-5.5"
# OPENROUTER_API_KEY=""
# OPENROUTER_HTTP_REFERER="http://localhost:3000"
# OPENROUTER_APP_TITLE="AgentSCAD"

# Optional OpenSCAD library search paths.
# CadCAD-managed libraries default to ~/.cadcad/openscad-libraries.
# Override the managed directory only when needed.
# CADCAD_OPENSCAD_LIBRARY_DIR="/Users/you/.cadcad/openscad-libraries"
#
# Point these at additional local BOSL/BOSL2/MCAD parent directories; do not vendor third-party code by default.
# Example macOS: OPENSCAD_LIBRARY_PATHS="/Users/you/Documents/OpenSCAD/libraries"
# Example multiple paths: OPENSCAD_LIBRARY_PATHS="/path/to/libs,/another/path"
# OPENSCAD_LIBRARY_PATHS=""

# Optional: Add other environment variables below
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Optional: Secret for cron endpoint authentication (if unset, cron endpoint is open)
# CRON_SECRET=""
