# Database URL for Prisma (SQLite by default)
DATABASE_URL="file:../db/dev.db"

# Xiaomi MiMo OpenAI-compatible API
MIMO_BASE_URL="https://token-plan-cn.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"
# MIMO_API_KEY=""

# DeepSeek OpenAI-compatible API
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
# DEEPSEEK_API_KEY=""

# OpenRouter OpenAI-compatible API
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-5.5"
# OPENROUTER_API_KEY=""
# OPENROUTER_HTTP_REFERER="http://localhost:3000"
# OPENROUTER_APP_TITLE="AgentSCAD"

# Optional OpenSCAD library search paths.
# AgentSCAD-managed libraries default to ~/.agentscad/openscad-libraries.
# Override the managed directory only when needed.
# AGENTSCAD_OPENSCAD_LIBRARY_DIR="/Users/you/.agentscad/openscad-libraries"
# Legacy CADCAD_OPENSCAD_LIBRARY_DIR is still accepted for existing local setups.
#
# Point these at additional local BOSL/BOSL2/MCAD parent directories; do not vendor third-party code by default.
# Example macOS: OPENSCAD_LIBRARY_PATHS="/Users/you/Documents/OpenSCAD/libraries"
# Example multiple paths: OPENSCAD_LIBRARY_PATHS="/path/to/libs,/another/path"
# OPENSCAD_LIBRARY_PATHS=""

# Optional: Add other environment variables below
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# ZHIPU_API_KEY=""
# ZAI_API_KEY=""
# MOONSHOT_API_KEY=""
# MINIMAX_API_KEY=""
# ARK_API_KEY=""
# DASHSCOPE_API_KEY=""
# MISTRAL_API_KEY=""
# GROQ_API_KEY=""
# TOGETHER_API_KEY=""
# LITELLM_API_KEY=""

# Secret for cron endpoint authentication (mandatory in production).
# Use a long random string, e.g.: openssl rand -hex 32
# CRON_SECRET=""

# Secret for job and chat API route authentication (mandatory in production).
# Protects /api/jobs, /api/chat, and related routes via middleware.
# Use a different secret than CRON_SECRET for defence in depth.
# API_SECRET=""
